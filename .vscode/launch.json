{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Run Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/AUTOFLOW AI/app.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/AUTOFLOW AI",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Running on (http://127\\.0\\.0\\.1:5001)",
                "uriFormat": "%s"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Open AUTOFLOW AI",
            "url": "http://127.0.0.1:5001",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Launch AUTOFLOW AI Web App",
            "configurations": [
                "Run Flask App"
            ]
        }
    ]
}